# Arquitectura del Sistema — Parte 2
## Modelos, Flujos y Socket.IO

---

## 6. Diseño de Modelos MongoDB/Mongoose

### User
```typescript
{
  _id: ObjectId,
  email: string,               // unique, indexed
  password: string,            // bcrypt hash
  dni: string,                 // unique
  firstName: string,
  lastName: string,
  role: 'citizen' | 'operator' | 'admin',
  phone?: string,
  address: string,
  location: {                  // GeoJSON Point
    type: 'Point',
    coordinates: [lng, lat]
  },
  zone: ObjectId,              // ref: Zone
  fcmToken?: string,           // Firebase token
  isActive: boolean,
  isVerified: boolean,
  verificationCode?: string,
  failedLoginAttempts: number,
  lockedUntil?: Date,
  notificationPreferences: {
    proximity: boolean,
    delays: boolean,
    incidentUpdates: boolean,
    radiusMeters: number       // default: 500
  },
  createdAt: Date,
  updatedAt: Date
}
// Índices: email (unique), dni (unique), location (2dsphere), zone
```

### Zone
```typescript
{
  _id: ObjectId,
  name: string,                // unique
  description: string,
  district: string,
  geometry: {                  // GeoJSON Polygon
    type: 'Polygon',
    coordinates: [[[lng, lat], ...]]
  },
  color: string,               // Para visualización en mapa
  isActive: boolean,
  createdBy: ObjectId,         // ref: User (admin)
  createdAt: Date,
  updatedAt: Date
}
// Índices: geometry (2dsphere), name (unique)
```

### Route
```typescript
{
  _id: ObjectId,
  name: string,
  zone: ObjectId,              // ref: Zone
  vehicle: ObjectId,           // ref: Vehicle
  operator: ObjectId,          // ref: User
  wasteTypes: [ObjectId],      // ref: WasteType
  schedule: {
    dayOfWeek: number[],       // 0=Dom, 1=Lun, ...
    startTime: string,         // "06:00"
    estimatedDuration: number  // minutos
  },
  waypoints: [{                // Paradas ordenadas
    order: number,
    name: string,
    location: {
      type: 'Point',
      coordinates: [lng, lat]
    },
    estimatedArrival: string   // "06:15"
  }],
  path: {                      // GeoJSON LineString
    type: 'LineString',
    coordinates: [[lng, lat], ...]
  },
  status: 'active' | 'inactive' | 'draft',
  createdBy: ObjectId,
  createdAt: Date,
  updatedAt: Date
}
// Índices: zone, operator, vehicle, path (2dsphere)
```

### RouteExecution
```typescript
{
  _id: ObjectId,
  route: ObjectId,             // ref: Route
  operator: ObjectId,          // ref: User
  vehicle: ObjectId,           // ref: Vehicle
  date: Date,
  startedAt: Date,
  endedAt?: Date,
  status: 'in_progress' | 'completed' | 'cancelled' | 'delayed',
  waypointsVisited: [{
    waypoint: number,          // order del waypoint
    arrivedAt: Date,
    skipped: boolean,
    skipReason?: string
  }],
  collectionData: {
    organicKg: number,
    recyclableKg: number,
    nonRecyclableKg: number,
    observations: string
  },
  incidents: [ObjectId],       // ref: Incident
  delayMinutes: number,
  createdAt: Date
}
// Índices: route + date (compound), operator, status
```

### GpsTrack
```typescript
{
  _id: ObjectId,
  routeExecution: ObjectId,    // ref: RouteExecution
  operator: ObjectId,          // ref: User
  location: {
    type: 'Point',
    coordinates: [lng, lat]
  },
  speed: number,               // km/h
  heading: number,             // grados
  accuracy: number,            // metros
  timestamp: Date,
  batteryLevel?: number
}
// Índices: routeExecution + timestamp (compound), location (2dsphere)
// TTL Index: timestamp (expira a los 90 días)
```

### Incident
```typescript
{
  _id: ObjectId,
  code: string,                // Código de seguimiento auto-generado
  type: 'accumulation' | 'damaged_container' | 'missed_collection'
       | 'road_blocked' | 'vehicle_breakdown' | 'other',
  reportedBy: ObjectId,        // ref: User
  reporterRole: 'citizen' | 'operator',
  description: string,
  images: [string],            // URLs (Cloudinary)
  location: {
    type: 'Point',
    coordinates: [lng, lat]
  },
  address: string,
  zone: ObjectId,              // ref: Zone
  status: 'pending' | 'in_review' | 'in_progress' | 'resolved' | 'dismissed',
  priority: 'low' | 'medium' | 'high' | 'critical',
  assignedTo?: ObjectId,       // ref: User (admin)
  resolution?: {
    description: string,
    resolvedAt: Date,
    resolvedBy: ObjectId
  },
  createdAt: Date,
  updatedAt: Date
}
// Índices: code (unique), location (2dsphere), zone, status, reportedBy
```

### Vehicle
```typescript
{
  _id: ObjectId,
  plate: string,               // unique
  type: 'compactor' | 'open_truck' | 'mini_truck',
  capacity: number,            // toneladas
  brand: string,
  model: string,
  year: number,
  status: 'available' | 'in_route' | 'maintenance' | 'inactive',
  currentLocation?: {
    type: 'Point',
    coordinates: [lng, lat]
  },
  lastMaintenanceDate?: Date,
  isActive: boolean,
  createdAt: Date
}
// Índices: plate (unique), status
```

### WasteType
```typescript
{
  _id: ObjectId,
  name: string,                // unique
  category: 'organic' | 'recyclable' | 'non_recyclable' | 'hazardous',
  description: string,
  examples: string[],
  handlingInstructions: string,
  colorCode: string,           // NTP 900.058
  icon: string,                // URL
  isActive: boolean,
  createdAt: Date
}
```

### Notification
```typescript
{
  _id: ObjectId,
  recipient: ObjectId,         // ref: User
  type: 'proximity' | 'delay' | 'incident_update' | 'schedule_change'
       | 'general' | 'system',
  title: string,
  body: string,
  data: Record<string, any>,   // Payload adicional
  channel: 'push' | 'in_app' | 'both',
  isRead: boolean,
  sentAt: Date,
  readAt?: Date
}
// Índices: recipient + sentAt (compound), isRead
// TTL Index: sentAt (expira a los 60 días)
```

