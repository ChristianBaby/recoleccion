# ─── Base de Datos ────────────────────────────────────────────────────────────
# PostgreSQL local:  postgresql://usuario:contraseña@localhost:5432/ecorutas_dev
# Supabase (prod):   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecorutas_dev"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera valores seguros con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_un_valor_aleatorio_muy_largo_access
JWT_REFRESH_SECRET=cambia_esto_por_un_valor_aleatorio_muy_largo_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
EMAIL_FROM="EcoRutas Cusco <noreply@ecorutas.pe>"
