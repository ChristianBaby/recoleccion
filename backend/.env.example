# ── Base de datos (Railway la genera automáticamente) ──────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Frontend (URL de Vercel — sin barra final) ─────────────────────────────────
# Para múltiples orígenes separar con coma:
FRONTEND_URL=https://tu-app.vercel.app

# ── JWT (genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_seguro_de_64_caracteres
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro_de_64_caracteres
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP (correo para verificación de email) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_de_gmail
EMAIL_FROM=EcoRutas Cusco <noreply@ecorutas.pe>
